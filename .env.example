# ─── Database ───────────────────────────────────────────
DATABASE_URL="postgresql://user:password@host:5432/founderstack"

# ─── Clerk Authentication ───────────────────────────────
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_live_...
CLERK_SECRET_KEY=sk_live_...

# Clerk redirect URLs
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
CLERK_INVITATION_REDIRECT_URL=https://your-web-domain.com/sign-up

# ─── CORS ──────────────────────────────────────────────
# The URL of your web app (for API CORS headers)
ALLOWED_ORIGIN=https://your-web-domain.com

# ─── Anthropic (Receipt OCR) ───────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ─── Resend (Email) ───────────────────────────────────
RESEND_API_KEY=re_...

# ─── AWS S3 / Cloudflare R2 (Future — Receipt Storage) ─
# AWS_S3_BUCKET=founderstack-receipts
# AWS_S3_REGION=us-east-1
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=

